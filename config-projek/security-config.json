{
  "version": "1.0",
  "note": "Template ikut Depoh security-config.js — nilai boleh ubah per customer",
  "idleLockPcMinutes": 60,
  "idleLockMobileMinutes": 120,
  "sessionMaxDays": 7,
  "maxDevicesPerUser": 2,
