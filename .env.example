# MSNC PeopleHub — Production (Windows Server)
# Salin fail ini ke .env.production.local

# Port Node.js (IIS reverse proxy ke port ini)
PORT=3000
HOSTNAME=0.0.0.0

# Nama company client (on-premise)
COMPANY_NAME=MSNC Group
COMPANY_CODE=MSNC

# Database (bila backend disambung)
# DATABASE_URL=postgresql://hrms:password@localhost:5432/peoplehub

# URL awam (untuk link & notifikasi)
# NEXT_PUBLIC_APP_URL=https://hrms.company.com